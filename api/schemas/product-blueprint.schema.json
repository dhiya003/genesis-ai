{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis-ai.local/schemas/product-blueprint.schema.json",
  "title": "Genesis Product Blueprint",
  "type": "object",
  "required": ["reportType", "projectId", "version", "recommendedProducts", "pricingStrategy", "launchSequence", "confidence"],
  "properties": {
    "reportType": { "const": "PRODUCT_BLUEPRINT" },
    "projectId": { "type": "string", "format": "uuid" },
    "version": { "type": "string" },
    "recommendedProducts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "category", "priority", "rationale"],
        "properties": {
          "name": { "type": "string" },
          "category": { "type": "string" },
          "priority": { "type": "integer", "minimum": 1, "maximum": 5 },
          "estimatedPrice": { "type": "number" },
          "estimatedCost": { "type": "number" },
          "estimatedMargin": { "type": "number" },
          "rationale": { "type": "string" }
        }
      }
    },
    "pricingStrategy": { "type": "object" },
    "collections": { "type": "array", "items": { "type": "object" } },
    "launchSequence": { "type": "array", "items": { "type": "string" } },
    "risks": { "type": "array", "items": { "type": "string" } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
