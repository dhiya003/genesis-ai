# Genesis AI local development environment

# Database
DATABASE_URL=postgresql://genesis:genesis_dev_password@localhost:5432/genesis
POSTGRES_USER=genesis
POSTGRES_PASSWORD=genesis_dev_password
POSTGRES_DB=genesis

# App
GENESIS_APP_NAME=genesis-ai
GENESIS_ENV=development
GENESIS_LOG_LEVEL=debug
GENESIS_API_HOST=127.0.0.1
GENESIS_API_PORT=8000
GENESIS_WORKER_QUEUE=manual-launch-pack
GENESIS_DATA_DIR=.genesis-data

# Research provider
# deterministic keeps Sprint 2 executable in CI without paid APIs.
# openai enables optional live AI employee execution when OPENAI_API_KEY is set.
# live_web and marketplace can use SerpAPI when SERPAPI_API_KEY is set.
GENESIS_RESEARCH_PROVIDER=deterministic
GENESIS_RESEARCH_MODEL=gpt-4.1-mini
GENESIS_SEARCH_PROVIDER=
SERPAPI_API_KEY=
SERPAPI_GOOGLE_DOMAIN=google.co.in
SERPAPI_GL=in
SERPAPI_HL=en

# Future integrations - do not commit real secrets
OPENAI_API_KEY=
GENESIS_CREATIVE_IMAGE_PROVIDER=deterministic
GENESIS_OPENAI_IMAGE_MODEL=gpt-image-2
GENESIS_OPENAI_IMAGE_LIMIT=3
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_DRIVE_ACCESS_TOKEN=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_TIMEOUT_SECONDS=60
META_APP_ID=
META_APP_SECRET=
QIKINK_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
