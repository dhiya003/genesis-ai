{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dhiya003/genesis-ai/api/schemas/sales-package.schema.json",
  "title": "Genesis Sprint 6 Sales Package API Schema",
  "type": "object",
  "required": [
    "reportType",
    "version",
    "projectId",
    "salesId",
    "marketingId",
    "creativeId",
    "productId",
    "workflowId",
    "department",
    "departmentStatus",
    "salesDepartment",
    "salesDirector",
    "salesExecutionPlan",
    "communicationChannels",
    "leadQualification",
    "salesConversations",
    "quotations",
    "followUpAutomation",
    "crmSynchronization",
    "salesPipeline",
    "orderHandoff",
    "salesAnalytics",
    "validationReport",
    "commercePublishingTransition",
    "employeeOutputs",
    "overallScore"
  ],
  "properties": {
    "reportType": { "const": "SALES_PACKAGE" },
    "version": { "type": "string" },
    "projectId": { "type": "string" },
    "salesId": { "type": "string" },
    "marketingId": { "type": "string" },
    "creativeId": { "type": "string" },
    "productId": { "type": "string" },
    "workflowId": { "type": "string" },
    "department": { "const": "SALES" },
    "departmentStatus": { "type": "string" },
    "salesDepartment": { "type": "object" },
    "salesDirector": { "type": "object" },
    "salesExecutionPlan": { "type": "array", "items": { "type": "string" } },
    "communicationChannels": { "type": "array", "items": { "type": "string" } },
    "leadQualification": { "type": "object" },
    "salesConversations": { "type": "object" },
    "quotations": { "type": "object" },
    "followUpAutomation": { "type": "object" },
    "crmSynchronization": { "type": "object" },
    "salesPipeline": { "type": "object" },
    "orderHandoff": { "type": "object" },
    "salesAnalytics": { "type": "object" },
    "validationReport": { "type": "object" },
    "commercePublishingTransition": { "type": "object" },
    "employeeOutputs": { "type": "array", "items": { "type": "object" } },
    "overallScore": { "type": "number", "minimum": 0, "maximum": 100 }
  }
}
