{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis-ai.local/schemas/research-report.schema.json",
  "title": "Genesis Research Report",
  "type": "object",
  "required": ["reportType", "projectId", "version", "scores", "recommendation", "confidence", "summary", "sections"],
  "properties": {
    "reportType": { "const": "RESEARCH_REPORT" },
    "projectId": { "type": "string", "format": "uuid" },
    "version": { "type": "string" },
    "scores": {
      "type": "object",
      "required": ["trend", "competition", "customer", "product", "overall"],
      "properties": {
        "trend": { "type": "integer", "minimum": 0, "maximum": 100 },
        "competition": { "type": "integer", "minimum": 0, "maximum": 100 },
        "customer": { "type": "integer", "minimum": 0, "maximum": 100 },
        "product": { "type": "integer", "minimum": 0, "maximum": 100 },
        "overall": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "recommendation": {
      "type": "string",
      "enum": ["APPROVE", "REJECT", "NEEDS_INVESTIGATION"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "summary": { "type": "string" },
    "sections": {
      "type": "object",
      "required": ["trend", "competitor", "customer", "product", "risks", "nextActions"],
      "properties": {
        "trend": { "type": "object" },
        "competitor": { "type": "object" },
        "customer": { "type": "object" },
        "product": { "type": "object" },
        "risks": { "type": "array", "items": { "type": "string" } },
        "nextActions": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
