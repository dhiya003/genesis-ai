{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dhiya003/genesis-ai/api/schemas/product-blueprint.schema.json",
  "title": "Genesis Product Blueprint",
  "type": "object",
  "required": [
    "reportType",
    "version",
    "projectId",
    "productId",
    "workflowId",
    "sourceReportId",
    "sourceWorkflowId",
    "sourceIdea",
    "department",
    "productName",
    "executiveSummary",
    "productDefinition",
    "productVariants",
    "engineeringSpecification",
    "materialRecommendation",
    "manufacturingPlan",
    "bom",
    "costAnalysis",
    "pricingStrategy",
    "packagingSpecification",
    "shippingPlan",
    "supplierRecommendations",
    "qualityChecklist",
    "profitabilityReport",
    "risks",
    "assumptions",
    "recommendations",
    "nextActions",
    "launchReadyEngineeringPackage",
    "employeeOutputs",
    "overallScore"
  ],
  "properties": {
    "reportType": { "const": "PRODUCT_BLUEPRINT" },
    "version": { "type": "string" },
    "projectId": { "type": "string" },
    "productId": { "type": "string" },
    "workflowId": { "type": "string" },
    "sourceReportId": { "type": "string" },
    "sourceWorkflowId": { "type": "string" },
    "sourceIdea": { "type": "string" },
    "department": { "const": "PRODUCT" },
    "productName": { "type": "string" },
    "executiveSummary": { "type": "string" },
    "productDefinition": { "type": "object" },
    "productVariants": { "type": "array" },
    "engineeringSpecification": { "type": "object" },
    "materialRecommendation": { "type": "object" },
    "manufacturingPlan": { "type": "object" },
    "bom": { "type": "object" },
    "costAnalysis": { "type": "object" },
    "pricingStrategy": { "type": "object" },
    "packagingSpecification": { "type": "object" },
    "shippingPlan": { "type": "object" },
    "supplierRecommendations": { "type": "object" },
    "qualityChecklist": { "type": "array" },
    "profitabilityReport": { "type": "object" },
    "risks": { "type": "array" },
    "assumptions": { "type": "array" },
    "recommendations": { "type": "array" },
    "nextActions": { "type": "array" },
    "launchReadyEngineeringPackage": { "type": "object" },
    "employeeOutputs": { "type": "array" },
    "overallScore": { "type": "number", "minimum": 0, "maximum": 100 }
  }
}
