{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dhiya003/genesis-ai/api/schemas/creative-pack.schema.json",
  "title": "Genesis Sprint 4 Creative Pack API Schema",
  "type": "object",
  "required": [
    "reportType",
    "version",
    "projectId",
    "creativeId",
    "productId",
    "workflowId",
    "department",
    "brandStrategy",
    "brandNameRecommendation",
    "brandIdentity",
    "logoSystem",
    "logoVariants",
    "logoUsageRules",
    "colorPalette",
    "typography",
    "visualIdentityRules",
    "visualSystem",
    "packagingDesignBrief",
    "packagingProductionAssets",
    "productMockupBrief",
    "productCreativeDeliverables",
    "marketplaceCreativePack",
    "socialMediaCreativePack",
    "digitalAssets",
    "launchCopyPack",
    "aiDeliverables",
    "creativeAssetManifest",
    "generatedAssets",
    "productionReadiness",
    "creativeQaReport",
    "validationReport",
    "founderApprovalChecklist",
    "risks",
    "assumptions",
    "nextActions",
    "assetGenerationPrompts",
    "employeeOutputs",
    "overallScore"
  ],
  "properties": {
    "reportType": { "const": "CREATIVE_PACK" },
    "version": { "type": "string" },
    "projectId": { "type": "string" },
    "creativeId": { "type": "string" },
    "productId": { "type": "string" },
    "workflowId": { "type": "string" },
    "department": { "const": "CREATIVE" },
    "brandStrategy": { "type": "object" },
    "brandNameRecommendation": { "type": "object" },
    "brandIdentity": { "type": "object" },
    "logoSystem": { "type": "object" },
    "logoVariants": { "type": "array", "items": { "type": "object" } },
    "logoUsageRules": { "type": "object" },
    "colorPalette": { "type": "array", "items": { "type": "object" } },
    "typography": { "type": "object" },
    "visualIdentityRules": { "type": "array", "items": { "type": "string" } },
    "visualSystem": { "type": "object" },
    "packagingDesignBrief": { "type": "object" },
    "packagingProductionAssets": { "type": "object" },
    "productMockupBrief": { "type": "object" },
    "productCreativeDeliverables": { "type": "object" },
    "marketplaceCreativePack": { "type": "object" },
    "socialMediaCreativePack": { "type": "object" },
    "digitalAssets": { "type": "object" },
    "launchCopyPack": { "type": "object" },
    "aiDeliverables": { "type": "object" },
    "creativeAssetManifest": { "type": "array", "items": { "type": "object" } },
    "generatedAssets": { "type": "object" },
    "productionReadiness": { "type": "object" },
    "creativeQaReport": { "type": "object" },
    "validationReport": { "type": "object" },
    "founderApprovalChecklist": { "type": "array", "items": { "type": "object" } },
    "risks": { "type": "array", "items": { "type": "object" } },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "nextActions": { "type": "array", "items": { "type": "string" } },
    "assetGenerationPrompts": { "type": "array", "items": { "type": "string" } },
    "employeeOutputs": { "type": "array", "items": { "type": "object" } },
    "overallScore": { "type": "number", "minimum": 0, "maximum": 100 }
  }
}
