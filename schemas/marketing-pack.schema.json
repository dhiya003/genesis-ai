{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dhiya003/genesis-ai/schemas/marketing-pack.schema.json",
  "title": "Genesis Sprint 5 Marketing Pack",
  "type": "object",
  "required": [
    "reportType",
    "version",
    "projectId",
    "marketingId",
    "creativeId",
    "productId",
    "workflowId",
    "department",
    "marketingStrategy",
    "launchPositioning",
    "customerPersonas",
    "goToMarketStrategy",
    "launchRoadmap",
    "marketingBudget",
    "channelPrioritization",
    "customerAcquisitionStrategy",
    "retentionStrategy",
    "referralStrategy",
    "seoPlan",
    "socialMediaPlan",
    "advertisingPlan",
    "marketplaceListing",
    "ecommerceDeliverables",
    "crmDeliverables",
    "salesFunnel",
    "analyticsPlan",
    "landingPageCopy",
    "emailCampaign",
    "whatsappCampaign",
    "influencerStrategy",
    "hashtagPlan",
    "launchPlan",
    "campaignQaReport",
    "aiDeliverables",
    "launchReadinessScore",
    "founderApprovalChecklist",
    "risks",
    "assumptions",
    "nextActions",
    "employeeOutputs",
    "overallScore"
  ],
  "properties": {
    "reportType": { "const": "MARKETING_PACK" },
    "version": { "type": "string" },
    "projectId": { "type": "string" },
    "marketingId": { "type": "string" },
    "creativeId": { "type": "string" },
    "productId": { "type": "string" },
    "workflowId": { "type": "string" },
    "department": { "const": "MARKETING" },
    "marketingStrategy": { "type": "object" },
    "launchPositioning": { "type": "string" },
    "customerPersonas": { "type": "array", "items": { "type": "object" } },
    "goToMarketStrategy": { "type": "string" },
    "launchRoadmap": { "type": "array", "items": { "type": "string" } },
    "marketingBudget": { "type": "object" },
    "channelPrioritization": { "type": "array", "items": { "type": "object" } },
    "customerAcquisitionStrategy": { "type": "string" },
    "retentionStrategy": { "type": "string" },
    "referralStrategy": { "type": "string" },
    "seoPlan": { "type": "object" },
    "socialMediaPlan": { "type": "object" },
    "advertisingPlan": { "type": "object" },
    "marketplaceListing": { "type": "object" },
    "ecommerceDeliverables": { "type": "object" },
    "crmDeliverables": { "type": "object" },
    "salesFunnel": { "type": "object" },
    "analyticsPlan": { "type": "object" },
    "landingPageCopy": { "type": "object" },
    "emailCampaign": { "type": "object" },
    "whatsappCampaign": { "type": "object" },
    "influencerStrategy": { "type": "object" },
    "hashtagPlan": { "type": "array", "items": { "type": "string" } },
    "launchPlan": { "type": "array", "items": { "type": "string" } },
    "campaignQaReport": { "type": "object" },
    "aiDeliverables": { "type": "object" },
    "launchReadinessScore": { "type": "object" },
    "founderApprovalChecklist": { "type": "array", "items": { "type": "object" } },
    "risks": { "type": "array", "items": { "type": "object" } },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "nextActions": { "type": "array", "items": { "type": "string" } },
    "employeeOutputs": { "type": "array", "items": { "type": "object" } },
    "overallScore": { "type": "number", "minimum": 0, "maximum": 100 }
  }
}
