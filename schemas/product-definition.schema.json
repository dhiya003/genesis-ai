{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dhiya003/genesis-ai/schemas/product-definition.schema.json",
  "title": "Genesis Product Definition",
  "type": "object",
  "required": [
    "reportType",
    "version",
    "projectId",
    "workflowId",
    "sourceReportId",
    "sourceWorkflowId",
    "sourceIdea",
    "department",
    "manager",
    "productDefinitionDocument",
    "opportunityReport",
    "variantMatrix",
    "productRoadmap",
    "constraintsReport",
    "successMetrics",
    "riskRegister",
    "approvalChecklist",
    "knowledgeBaseEntries"
  ],
  "properties": {
    "reportType": { "const": "PRODUCT_DEFINITION" },
    "version": { "type": "string" },
    "projectId": { "type": "string" },
    "workflowId": { "type": "string" },
    "sourceReportId": { "type": "string" },
    "sourceWorkflowId": { "type": "string" },
    "sourceIdea": { "type": "string" },
    "department": { "const": "PRODUCT" },
    "manager": { "type": "string" },
    "productDefinitionDocument": { "type": "object" },
    "opportunityReport": { "type": "object" },
    "variantMatrix": { "type": "array" },
    "productRoadmap": { "type": "object" },
    "constraintsReport": { "type": "object" },
    "successMetrics": { "type": "object" },
    "riskRegister": { "type": "array" },
    "approvalChecklist": { "type": "array" },
    "knowledgeBaseEntries": { "type": "array" }
  }
}
