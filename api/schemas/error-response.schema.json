{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis-ai.local/schemas/error-response.schema.json",
  "title": "Genesis Error Response",
  "type": "object",
  "required": ["code", "message", "severity"],
  "properties": {
    "code": { "type": "string" },
    "message": { "type": "string" },
    "severity": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
    "source": { "type": "string" },
    "retryAllowed": { "type": "boolean" },
    "details": { "type": "object" }
  }
}
